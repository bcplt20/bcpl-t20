modules = ["nodejs-24", "python-base-3.13", "postgresql-16"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "typecheck"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "api-tests"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "web-typecheck"

[[workflows.workflow]]
name = "typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/api-server && pnpm exec tsc --noEmit"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "api-tests"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/api-server && pnpm exec vitest run"

[workflows.workflow.metadata]
isValidation = true

[[workflows.workflow]]
name = "web-typecheck"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd artifacts/bcpl-website && pnpm exec tsc --noEmit"

[workflows.workflow.metadata]
isValidation = true

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[userenv]

[userenv.shared]
API_URL = "https://elite-user-experience.replit.app"
AWS_REGION = "ap-south-1"
AWS_S3_BUCKET = "bcpl-trial-videos"
BREVO_FROM_EMAIL = "info@bcplt20.com"
CASHFREE_ENV = "PROD"
SITE_URL = "https://bcplt20.com/bcpl-website"
VITE_ADMIN_KEY = ""
ADMIN_PANEL_PASSWORD = "BCPL@S5#2026!"
ADMIN_ALERT_EMAIL = "saurabhjha@bcplt20.com"

[nix]
channel = "stable-25_05"
