# ============================================================
# BCPL T20 — Production Environment Variables
# Save as: /home/bcpl/app/.env.production
# NEVER commit this file to git!
# ============================================================

# ── Database (AWS RDS — fill after RDS setup) ───────────────
DATABASE_URL=postgresql://bcpluser:YOUR_PASSWORD@YOUR_RDS_ENDPOINT:5432/bcpldb

# ── AWS ─────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=YOUR_AWS_ACCESS_KEY
AWS_SECRET_ACCESS_KEY=YOUR_AWS_SECRET_KEY
AWS_S3_BUCKET=bcpl-trial-videos
AWS_REGION=ap-south-1

# ── Auth ────────────────────────────────────────────────────
JWT_SECRET=GENERATE_A_LONG_RANDOM_STRING_HERE
SESSION_SECRET=ANOTHER_LONG_RANDOM_STRING_HERE
ADMIN_SECRET=YOUR_ADMIN_PANEL_PASSWORD

# ── SMS OTP (2Factor) ────────────────────────────────────────
TWOFACTOR_API_KEY=YOUR_2FACTOR_API_KEY

# ── Email (Brevo) ────────────────────────────────────────────
BREVO_API_KEY=YOUR_BREVO_API_KEY
BREVO_FROM_EMAIL=noreply@bcplt20.com

# ── WhatsApp (Interakt) ──────────────────────────────────────
INTERAKT_API_KEY=YOUR_INTERAKT_API_KEY

# ── Payment (Cashfree) ───────────────────────────────────────
CASHFREE_APP_ID=YOUR_CASHFREE_APP_ID
CASHFREE_SECRET_KEY=YOUR_CASHFREE_SECRET_KEY
CASHFREE_ENV=PROD

# ── Site ─────────────────────────────────────────────────────
NODE_ENV=production
SITE_URL=https://bcplt20.com
API_URL=https://bcplt20.com
PORT=4000
